{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "blocks",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Ferretería/Herramientas",
        "Repuestos/Accesorios",
        "Hogar/Electro",
        "Sin categoria"
      ]
    },
    "subCategory": {
      "type": "enumeration",
      "enum": [
        "htas eléctricas",
        "htas  manuales",
        "htas  medición",
        "electricidad",
        "Cintas métricas",
        "Accesorios",
        "iluminación",
        "construcción",
        "computación",
        "Muebles y decoración",
        "Camas y colchones",
        "seguridad",
        "cocina",
        "comedor",
        "Armarios",
        "Organización",
        "baño",
        "jardín"
      ]
    },
    "price": {
      "type": "integer",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
